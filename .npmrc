# GitHub Packages scope routing.
# Committed to the repo. Contains NO secrets.
#
# Authentication is provided separately:
#   - Local dev:  add `//npm.pkg.github.com/:_authToken=YOUR_PAT` to ~/.npmrc
#                 (PAT scopes: read:packages; write:packages for maintainers).
#   - CI:         GitHub Actions sets NODE_AUTH_TOKEN automatically via
#                 actions/setup-node + secrets.GITHUB_TOKEN.
#
@abd-maqableh:registry=https://npm.pkg.github.com
