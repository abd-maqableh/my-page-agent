{
  "name": "@abd-maqableh/page-agent",
  "version": "0.1.0",
  "description": "In-page LLM-driven browser agent (framework-agnostic).",
  "type": "module",
  "license": "UNLICENSED",
  "author": "Abdallah Maqableh",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abd-maqableh/my-page-agent.git"
  },
  "homepage": "https://github.com/abd-maqableh/my-page-agent#readme",
  "bugs": {
    "url": "https://github.com/abd-maqableh/my-page-agent/issues"
  },
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "packageManager": "yarn@1.22.22",
  "scripts": {
    "dev": "vite --config vite.demo.config.ts",
    "build": "nx build",
    "test": "nx test",
    "lint": "nx lint",
    "typecheck": "nx typecheck",
    "preview": "vite preview --config vite.demo.config.ts",
    "release": "nx release",
    "release:dry": "nx release --dry-run"
  },
  "peerDependenciesMeta": {
    "ollama": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nx/js": "22.7.5",
    "@nx/vite": "22.7.5",
    "@types/node": "^22.10.0",
    "jsdom": "^25.0.1",
    "nx": "22.7.5",
    "typescript": "~5.7.2",
    "vite": "^6.3.5",
    "vite-plugin-dts": "^4.3.0",
    "vitest": "^4.1.0"
  },
  "resolutions": {
    "brace-expansion": "^5.0.6",
    "ws": "^8.20.1",
    "vite": "^6.3.5"
  }
}
